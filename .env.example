# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Public host where the app is available.
APP_HOST="http://localhost"

# Host ports for docker-compose services.
FRONTEND_PORT="3001"
BACKEND_PORT="8001"

# Backend CORS configuration.
CORS_ALLOW_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"
CORS_ALLOW_METHODS="*"
CORS_ALLOW_HEADERS="*"
CORS_ALLOW_CREDENTIALS="true"

# Optional API base URL used by frontend code when calling backend API.
VITE_API_BASE_URL="http://localhost:8001"
